{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "start": "pnpm --filter @workspace/api-server run start",
    "dev": "concurrently --names \"BACKEND,DASHBOARD\" --prefix-colors \"green,cyan\" \"pnpm --filter @workspace/api-server run dev\" \"pnpm --filter @workspace/bot-dashboard run dev\"",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0"
  }
}
