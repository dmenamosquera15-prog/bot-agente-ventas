# Base de datos - CAMBIAR VALORES SEGÚN TU CONFIGURACIÓN
DATABASE_URL=postgresql://postgres:password@localhost:5432/intelligent_agent_db

# API Server
PORT=3000
NODE_ENV=development

# Proveedores de IA (dejar vacío si no se usa)
# Para obtener estas claves, visita los sitios respectivos:

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Groq - https://console.groq.com
GROQ_API_KEY=

# Anthropic - https://console.anthropic.com
ANTHROPIC_API_KEY=

# Grok/xAI - https://grok.x.ai
GROK_API_KEY=

# OpenRouter - https://openrouter.ai
OPENROUTER_API_KEY=

# GitHub Integration (Opcional)
# Para obtener: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=daveymena/bot-agente-ventas3

# WhatsApp (Baileys)
# Formato: +1234567890 (con código de país)
WHATSAPP_PHONE_NUMBER=

# Configuraciones adicionales
LOG_LEVEL=info
